194: 	const float LUT_SIZE = 64.0;
195: 	const float LUT_SCALE = ( LUT_SIZE - 1.0 ) / LUT_SIZE;
196: 	const float LUT_BIAS = 0.5 / LUT_SIZE;
197: 	float dotNV = saturate( dot( N, V ) );
198: 	vec2 uv = vec2( roughness, sqrt( 1.0 - dotNV ) );
199: 	uv = uv * LUT_SCALE + LUT_BIAS;
200: 	return uv;
