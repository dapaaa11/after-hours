257: float D_Charlie( float roughness, float dotNH ) {
258: 	float alpha = pow2( roughness );
259: 	float invAlpha = 1.0 / alpha;
260: 	float cos2h = dotNH * dotNH;
261: 	float sin2h = max( 1.0 - cos2h, 0.0078125 );
