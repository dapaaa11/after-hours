612: 		bvec4 inFrustumVec = bvec4 ( shadowCoord.x >= 0.0, shadowCoord.x <= 1.0, shadowCoord.y >= 0.0, shadowCoord.y <= 1.0 );
613: 		bool inFrustum = all( inFrustumVec );
614: 		bvec2 frustumTestVec = bvec2( inFrustum, shadowCoord.z <= 1.0 );
615: 		bool frustumTest = all( frustumTestVec );
616: 		if ( frustumTest ) {
