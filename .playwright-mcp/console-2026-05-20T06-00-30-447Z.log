692: 		float almostATexel = 1.5 * texelSizeY;
693: 		float almostOne = 1.0 - almostATexel;
694: 		if ( absV.z >= almostOne ) {
695: 			if ( v.z > 0.0 )
696: 				planar.x = 4.0 - v.x;
697: 		} else if ( absV.x >= almostOne ) {
698: 			float signX = sign( v.x );
699: 			planar.x = v.z * signX + 2.0 * signX;
700: 		} else if ( absV.y >= almostOne ) {
701: 			float signY = sign( v.y );
702: 			planar.x = v.x + 2.0 * signY + 2.0;
703: 			planar.y = v.z * signY - 2.0;
704: 		}
705: 		return vec2( 0.125, 0.25 ) * planar + vec2( 0.375, 0.75 );
