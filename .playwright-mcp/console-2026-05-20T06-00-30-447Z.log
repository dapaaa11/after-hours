242: 			uv = vec2( direction.x, direction.y ) / abs( direction.z );
243: 		}
244: 		return 0.5 * ( uv + 1.0 );
245: 	}
246: 	vec3 bilinearCubeUV( sampler2D envMap, vec3 direction, float mipInt ) {
247: 		float face = getFace( direction );
248: 		float filterInt = max( cubeUV_minMipLevel - mipInt, 0.0 );
249: 		mipInt = max( mipInt, cubeUV_minMipLevel );
250: 		float faceSize = exp2( mipInt );
251: 		float texelSize = 1.0 / ( 3.0 * cubeUV_maxTileSize );
252: 		vec2 uv = getUV( direction, face ) * ( faceSize - 1.0 ) + 0.5;
253: 		if ( face > 2.0 ) {
254: 			uv.y += faceSize;
255: 			face -= 3.0;
256: 		}
257: 		uv.x += face * faceSize;
258: 		if ( mipInt < cubeUV_maxMipLevel ) {
259: 			uv.y += 2.0 * cubeUV_maxTileSize;
260: 		}
261: 		uv.y += filterInt * 2.0 * cubeUV_minTileSize;
262: 		uv.x += 3.0 * max( 0.0, cubeUV_maxTileSize - 2.0 * faceSize );
263: 		uv *= texelSize;
264: 		return texture2D( envMap, uv ).rgb;
265: 	}
266: 	#define r0 1.0
267: 	#define v0 0.339
268: 	#define m0 - 2.0
269: 	#define r1 0.8
270: 	#define v1 0.276
271: 	#define m1 - 1.0
272: 	#define r4 0.4
273: 	#define v4 0.046
274: 	#define m4 2.0
275: 	#define r5 0.305
276: 	#define v5 0.016
277: 	#define m5 3.0
278: 	#define r6 0.21
279: 	#define v6 0.0038
280: 	#define m6 4.0
281: 	float roughnessToMip( float roughness ) {
282: 		float mip = 0.0;
283: 		if ( roughness >= r1 ) {
284: 			mip = ( r0 - roughness ) * ( m1 - m0 ) / ( r0 - r1 ) + m0;
285: 		} else if ( roughness >= r4 ) {
286: 			mip = ( r1 - roughness ) * ( m4 - m1 ) / ( r1 - r4 ) + m1;
287: 		} else if ( roughness >= r5 ) {
288: 			mip = ( r4 - roughness ) * ( m5 - m4 ) / ( r4 - r5 ) + m4;
289: 		} else if ( roughness >= r6 ) {
290: 			mip = ( r5 - roughness ) * ( m6 - m5 ) / ( r5 - r6 ) + m5;
291: 		} else {
292: 			mip = - 2.0 * log2( 1.16 * roughness );		}
293: 		return mip;
294: 	}
295: 	vec4 textureCubeUV( sampler2D envMap, vec3 sampleDir, float roughness ) {
296: 		float mip = clamp( roughnessToMip( roughness ), m0, cubeUV_maxMipLevel );
297: 		float mipF = fract( mip );
298: 		float mipInt = floor( mip );
299: 		vec3 color0 = bilinearCubeUV( envMap, sampleDir, mipInt );
300: 		if ( mipF == 0.0 ) {
301: 			return vec4( color0, 1.0 );
302: 		} else {
303: 			vec3 color1 = bilinearCubeUV( envMap, sampleDir, mipInt + 1.0 );
304: 			return vec4( mix( color0, color1, mipF ), 1.0 );
305: 		}
306: 	}
307: #endif
308: vec3 BRDF_Lambert( const in vec3 diffuseColor ) {
309: 	return RECIPROCAL_PI * diffuseColor;
310: }
311: vec3 F_Schlick( const in vec3 f0, const in float f90, const in float dotVH ) {
312: 	float fresnel = exp2( ( - 5.55473 * dotVH - 6.98316 ) * dotVH );
313: 	return f0 * ( 1.0 - fresnel ) + ( f90 * fresnel );
314: }
315: float V_GGX_SmithCorrelated( const in float alpha, const in float dotNL, const in float dotNV ) {
316: 	float a2 = pow2( alpha );
317: 	float gv = dotNL * sqrt( a2 + ( 1.0 - a2 ) * pow2( dotNV ) );
318: 	float gl = dotNV * sqrt( a2 + ( 1.0 - a2 ) * pow2( dotNL ) );
319: 	return 0.5 / max( gv + gl, EPSILON );
320: }
321: float D_GGX( const in float alpha, const in float dotNH ) {
322: 	float a2 = pow2( alpha );
323: 	float denom = pow2( dotNH ) * ( a2 - 1.0 ) + 1.0;
324: 	return RECIPROCAL_PI * a2 / pow2( denom );
325: }
326: vec3 BRDF_GGX( const in vec3 lightDir, const in vec3 viewDir, const in vec3 normal, const in vec3 f0, const in float f90, const in float roughness ) {
327: 	float alpha = pow2( roughness );
328: 	vec3 halfDir = normalize( lightDir + viewDir );
329: 	float dotNL = saturate( dot( normal, lightDir ) );
330: 	float dotNV = saturate( dot( normal, viewDir ) );
331: 	float dotNH = saturate( dot( normal, halfDir ) );
332: 	float dotVH = saturate( dot( viewDir, halfDir ) );
333: 	vec3 F = F_Schlick( f0, f90, dotVH );
334: 	float V = V_GGX_SmithCorrelated( alpha, dotNL, dotNV );
335: 	float D = D_GGX( alpha, dotNH );
336: 	return F * ( V * D );
337: }
338: vec2 LTC_Uv( const in vec3 N, const in vec3 V, const in float roughness ) {
339: 	const float LUT_SIZE = 64.0;
340: 	const float LUT_SCALE = ( LUT_SIZE - 1.0 ) / LUT_SIZE;
341: 	const float LUT_BIAS = 0.5 / LUT_SIZE;
342: 	float dotNV = saturate( dot( N, V ) );
343: 	vec2 uv = vec2( roughness, sqrt( 1.0 - dotNV ) );
344: 	uv = uv * LUT_SCALE + LUT_BIAS;
345: 	return uv;
346: }
347: float LTC_ClippedSphereFormFactor( const in vec3 f ) {
348: 	float l = length( f );
349: 	return max( ( l * l + f.z ) / ( l + 1.0 ), 0.0 );
350: }
351: vec3 LTC_EdgeVectorFormFactor( const in vec3 v1, const in vec3 v2 ) {
352: 	float x = dot( v1, v2 );
353: 	float y = abs( x );
354: 	float a = 0.8543985 + ( 0.4965155 + 0.0145206 * y ) * y;
355: 	float b = 3.4175940 + ( 4.1616724 + y ) * y;
356: 	float v = a / b;
357: 	float theta_sintheta = ( x > 0.0 ) ? v : 0.5 * inversesqrt( max( 1.0 - x * x, 1e-7 ) ) - v;
358: 	return cross( v1, v2 ) * theta_sintheta;
359: }
360: vec3 LTC_Evaluate( const in vec3 N, const in vec3 V, const in vec3 P, const in mat3 mInv, const in vec3 rectCoords[ 4 ] ) {
361: 	vec3 v1 = rectCoords[ 1 ] - rectCoords[ 0 ];
362: 	vec3 v2 = rectCoords[ 3 ] - rectCoords[ 0 ];
363: 	vec3 lightNormal = cross( v1, v2 );
364: 	if( dot( lightNormal, P - rectCoords[ 0 ] ) < 0.0 ) return vec3( 0.0 );
365: 	vec3 T1, T2;
366: 	T1 = normalize( V - N * dot( V, N ) );
367: 	T2 = - cross( N, T1 );
368: 	mat3 mat = mInv * transposeMat3( mat3( T1, T2, N ) );
369: 	vec3 coords[ 4 ];
370: 	coords[ 0 ] = mat * ( rectCoords[ 0 ] - P );
371: 	coords[ 1 ] = mat * ( rectCoords[ 1 ] - P );
372: 	coords[ 2 ] = mat * ( rectCoords[ 2 ] - P );
373: 	coords[ 3 ] = mat * ( rectCoords[ 3 ] - P );
374: 	coords[ 0 ] = normalize( coords[ 0 ] );
375: 	coords[ 1 ] = normalize( coords[ 1 ] );
376: 	coords[ 2 ] = normalize( coords[ 2 ] );
377: 	coords[ 3 ] = normalize( coords[ 3 ] );
378: 	vec3 vectorFormFactor = vec3( 0.0 );
379: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 0 ], coords[ 1 ] );
380: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 1 ], coords[ 2 ] );
381: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 2 ], coords[ 3 ] );
382: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 3 ], coords[ 0 ] );
383: 	float result = LTC_ClippedSphereFormFactor( vectorFormFactor );
384: 	return vec3( result );
385: }
386: float G_BlinnPhong_Implicit( ) {
387: 	return 0.25;
388: }
389: float D_BlinnPhong( const in float shininess, const in float dotNH ) {
390: 	return RECIPROCAL_PI * ( shininess * 0.5 + 1.0 ) * pow( dotNH, shininess );
391: }
392: vec3 BRDF_BlinnPhong( const in vec3 lightDir, const in vec3 viewDir, const in vec3 normal, const in vec3 specularColor, const in float shininess ) {
393: 	vec3 halfDir = normalize( lightDir + viewDir );
394: 	float dotNH = saturate( dot( normal, halfDir ) );
395: 	float dotVH = saturate( dot( viewDir, halfDir ) );
396: 	vec3 F = F_Schlick( specularColor, 1.0, dotVH );
397: 	float G = G_BlinnPhong_Implicit( );
398: 	float D = D_BlinnPhong( shininess, dotNH );
399: 	return F * ( G * D );
400: }
