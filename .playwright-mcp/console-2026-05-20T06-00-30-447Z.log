284: 	result += shCoefficients[ 1 ] * 2.0 * 0.511664 * y;
285: 	result += shCoefficients[ 2 ] * 2.0 * 0.511664 * z;
286: 	result += shCoefficients[ 3 ] * 2.0 * 0.511664 * x;
287: 	result += shCoefficients[ 4 ] * 2.0 * 0.429043 * x * y;
288: 	result += shCoefficients[ 5 ] * 2.0 * 0.429043 * y * z;
289: 	result += shCoefficients[ 6 ] * ( 0.743125 * z * z - 0.247708 );
290: 	result += shCoefficients[ 7 ] * 2.0 * 0.429043 * x * z;
291: 	result += shCoefficients[ 8 ] * 0.429043 * ( x * x - y * y );
292: 	return result;
