182: vec3 BRDF_GGX( const in vec3 lightDir, const in vec3 viewDir, const in vec3 normal, const in vec3 f0, const in float f90, const in float roughness ) {
183: 	float alpha = pow2( roughness );
184: 	vec3 halfDir = normalize( lightDir + viewDir );
185: 	float dotNL = saturate( dot( normal, lightDir ) );
186: 	float dotNV = saturate( dot( normal, viewDir ) );
187: 	float dotNH = saturate( dot( normal, halfDir ) );
188: 	float dotVH = saturate( dot( viewDir, halfDir ) );
189: 	vec3 F = F_Schlick( f0, f90, dotVH );
190: 	float V = V_GGX_SmithCorrelated( alpha, dotNL, dotNV );
191: 	float D = D_GGX( alpha, dotNH );
192: 	return F * ( V * D );
193: }
194: vec2 LTC_Uv( const in vec3 N, const in vec3 V, const in float roughness ) {
195: 	const float LUT_SIZE = 64.0;
196: 	const float LUT_SCALE = ( LUT_SIZE - 1.0 ) / LUT_SIZE;
197: 	const float LUT_BIAS = 0.5 / LUT_SIZE;
198: 	float dotNV = saturate( dot( N, V ) );
199: 	vec2 uv = vec2( roughness, sqrt( 1.0 - dotNV ) );
200: 	uv = uv * LUT_SCALE + LUT_BIAS;
201: 	return uv;
202: }
203: float LTC_ClippedSphereFormFactor( const in vec3 f ) {
204: 	float l = length( f );
205: 	return max( ( l * l + f.z ) / ( l + 1.0 ), 0.0 );
206: }
207: vec3 LTC_EdgeVectorFormFactor( const in vec3 v1, const in vec3 v2 ) {
208: 	float x = dot( v1, v2 );
209: 	float y = abs( x );
210: 	float a = 0.8543985 + ( 0.4965155 + 0.0145206 * y ) * y;
211: 	float b = 3.4175940 + ( 4.1616724 + y ) * y;
212: 	float v = a / b;
213: 	float theta_sintheta = ( x > 0.0 ) ? v : 0.5 * inversesqrt( max( 1.0 - x * x, 1e-7 ) ) - v;
214: 	return cross( v1, v2 ) * theta_sintheta;
215: }
216: vec3 LTC_Evaluate( const in vec3 N, const in vec3 V, const in vec3 P, const in mat3 mInv, const in vec3 rectCoords[ 4 ] ) {
217: 	vec3 v1 = rectCoords[ 1 ] - rectCoords[ 0 ];
218: 	vec3 v2 = rectCoords[ 3 ] - rectCoords[ 0 ];
219: 	vec3 lightNormal = cross( v1, v2 );
220: 	if( dot( lightNormal, P - rectCoords[ 0 ] ) < 0.0 ) return vec3( 0.0 );
221: 	vec3 T1, T2;
222: 	T1 = normalize( V - N * dot( V, N ) );
223: 	T2 = - cross( N, T1 );
224: 	mat3 mat = mInv * transposeMat3( mat3( T1, T2, N ) );
225: 	vec3 coords[ 4 ];
226: 	coords[ 0 ] = mat * ( rectCoords[ 0 ] - P );
227: 	coords[ 1 ] = mat * ( rectCoords[ 1 ] - P );
228: 	coords[ 2 ] = mat * ( rectCoords[ 2 ] - P );
229: 	coords[ 3 ] = mat * ( rectCoords[ 3 ] - P );
230: 	coords[ 0 ] = normalize( coords[ 0 ] );
231: 	coords[ 1 ] = normalize( coords[ 1 ] );
232: 	coords[ 2 ] = normalize( coords[ 2 ] );
233: 	coords[ 3 ] = normalize( coords[ 3 ] );
234: 	vec3 vectorFormFactor = vec3( 0.0 );
235: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 0 ], coords[ 1 ] );
236: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 1 ], coords[ 2 ] );
237: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 2 ], coords[ 3 ] );
238: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 3 ], coords[ 0 ] );
239: 	float result = LTC_ClippedSphereFormFactor( vectorFormFactor );
240: 	return vec3( result );
241: }
