302: float getDistanceAttenuation( const in float lightDistance, const in float cutoffDistance, const in float decayExponent ) {
303: 	#if defined ( PHYSICALLY_CORRECT_LIGHTS )
304: 		float distanceFalloff = 1.0 / max( pow( lightDistance, decayExponent ), 0.01 );
305: 		if ( cutoffDistance > 0.0 ) {
