426: vec3 shGetIrradianceAt( in vec3 normal, in vec3 shCoefficients[ 9 ] ) {
427: 	float x = normal.x, y = normal.y, z = normal.z;
428: 	vec3 result = shCoefficients[ 0 ] * 0.886227;
429: 	result += shCoefficients[ 1 ] * 2.0 * 0.511664 * y;
430: 	result += shCoefficients[ 2 ] * 2.0 * 0.511664 * z;
431: 	result += shCoefficients[ 3 ] * 2.0 * 0.511664 * x;
432: 	result += shCoefficients[ 4 ] * 2.0 * 0.429043 * x * y;
433: 	result += shCoefficients[ 5 ] * 2.0 * 0.429043 * y * z;
434: 	result += shCoefficients[ 6 ] * ( 0.743125 * z * z - 0.247708 );
435: 	result += shCoefficients[ 7 ] * 2.0 * 0.429043 * x * z;
436: 	result += shCoefficients[ 8 ] * 0.429043 * ( x * x - y * y );
437: 	return result;
438: }
