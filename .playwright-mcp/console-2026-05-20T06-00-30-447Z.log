448: float getDistanceAttenuation( const in float lightDistance, const in float cutoffDistance, const in float decayExponent ) {
449: 	#if defined ( PHYSICALLY_CORRECT_LIGHTS )
450: 		float distanceFalloff = 1.0 / max( pow( lightDistance, decayExponent ), 0.01 );
451: 		if ( cutoffDistance > 0.0 ) {
452: 			distanceFalloff *= pow2( saturate( 1.0 - pow4( lightDistance / cutoffDistance ) ) );
453: 		}
454: 		return distanceFalloff;
455: 	#else
456: 		if ( cutoffDistance > 0.0 && decayExponent > 0.0 ) {
457: 			return pow( saturate( - lightDistance / cutoffDistance + 1.0 ), decayExponent );
458: 		}
459: 		return 1.0;
460: 	#endif
461: }
