402: float D_Charlie( float roughness, float dotNH ) {
403: 	float alpha = pow2( roughness );
404: 	float invAlpha = 1.0 / alpha;
405: 	float cos2h = dotNH * dotNH;
406: 	float sin2h = max( 1.0 - cos2h, 0.0078125 );
407: 	return ( 2.0 + invAlpha ) * pow( sin2h, invAlpha * 0.5 ) / ( 2.0 * PI );
408: }
409: float V_Neubelt( float dotNV, float dotNL ) {
410: 	return saturate( 1.0 / ( 4.0 * ( dotNL + dotNV - dotNL * dotNV ) ) );
411: }
412: vec3 BRDF_Sheen( const in vec3 lightDir, const in vec3 viewDir, const in vec3 normal, vec3 sheenColor, const in float sheenRoughness ) {
413: 	vec3 halfDir = normalize( lightDir + viewDir );
414: 	float dotNL = saturate( dot( normal, lightDir ) );
415: 	float dotNV = saturate( dot( normal, viewDir ) );
416: 	float dotNH = saturate( dot( normal, halfDir ) );
417: 	float D = D_Charlie( sheenRoughness, dotNH );
418: 	float V = V_Neubelt( dotNV, dotNL );
419: 	return sheenColor * ( D * V );
420: }
