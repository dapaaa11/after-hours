366: 	T1 = normalize( V - N * dot( V, N ) );
367: 	T2 = - cross( N, T1 );
368: 	mat3 mat = mInv * transposeMat3( mat3( T1, T2, N ) );
369: 	vec3 coords[ 4 ];
370: 	coords[ 0 ] = mat * ( rectCoords[ 0 ] - P );
371: 	coords[ 1 ] = mat * ( rectCoords[ 1 ] - P );
372: 	coords[ 2 ] = mat * ( rectCoords[ 2 ] - P );
373: 	coords[ 3 ] = mat * ( rectCoords[ 3 ] - P );
374: 	coords[ 0 ] = normalize( coords[ 0 ] );
375: 	coords[ 1 ] = normalize( coords[ 1 ] );
376: 	coords[ 2 ] = normalize( coords[ 2 ] );
377: 	coords[ 3 ] = normalize( coords[ 3 ] );
378: 	vec3 vectorFormFactor = vec3( 0.0 );
379: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 0 ], coords[ 1 ] );
380: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 1 ], coords[ 2 ] );
381: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 2 ], coords[ 3 ] );
382: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 3 ], coords[ 0 ] );
