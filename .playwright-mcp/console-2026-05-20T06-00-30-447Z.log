206: vec3 LTC_EdgeVectorFormFactor( const in vec3 v1, const in vec3 v2 ) {
207: 	float x = dot( v1, v2 );
208: 	float y = abs( x );
209: 	float a = 0.8543985 + ( 0.4965155 + 0.0145206 * y ) * y;
210: 	float b = 3.4175940 + ( 4.1616724 + y ) * y;
211: 	float v = a / b;
212: 	float theta_sintheta = ( x > 0.0 ) ? v : 0.5 * inversesqrt( max( 1.0 - x * x, 1e-7 ) ) - v;
213: 	return cross( v1, v2 ) * theta_sintheta;
214: }
215: vec3 LTC_Evaluate( const in vec3 N, const in vec3 V, const in vec3 P, const in mat3 mInv, const in vec3 rectCoords[ 4 ] ) {
216: 	vec3 v1 = rectCoords[ 1 ] - rectCoords[ 0 ];
217: 	vec3 v2 = rectCoords[ 3 ] - rectCoords[ 0 ];
218: 	vec3 lightNormal = cross( v1, v2 );
219: 	if( dot( lightNormal, P - rectCoords[ 0 ] ) < 0.0 ) return vec3( 0.0 );
220: 	vec3 T1, T2;
221: 	T1 = normalize( V - N * dot( V, N ) );
222: 	T2 = - cross( N, T1 );
223: 	mat3 mat = mInv * transposeMat3( mat3( T1, T2, N ) );
224: 	vec3 coords[ 4 ];
225: 	coords[ 0 ] = mat * ( rectCoords[ 0 ] - P );
226: 	coords[ 1 ] = mat * ( rectCoords[ 1 ] - P );
227: 	coords[ 2 ] = mat * ( rectCoords[ 2 ] - P );
228: 	coords[ 3 ] = mat * ( rectCoords[ 3 ] - P );
229: 	coords[ 0 ] = normalize( coords[ 0 ] );
230: 	coords[ 1 ] = normalize( coords[ 1 ] );
231: 	coords[ 2 ] = normalize( coords[ 2 ] );
232: 	coords[ 3 ] = normalize( coords[ 3 ] );
233: 	vec3 vectorFormFactor = vec3( 0.0 );
234: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 0 ], coords[ 1 ] );
235: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 1 ], coords[ 2 ] );
236: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 2 ], coords[ 3 ] );
237: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 3 ], coords[ 0 ] );
238: 	float result = LTC_ClippedSphereFormFactor( vectorFormFactor );
239: 	return vec3( result );
240: }
