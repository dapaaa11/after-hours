447: float getDistanceAttenuation( const in float lightDistance, const in float cutoffDistance, const in float decayExponent ) {
448: 	#if defined ( PHYSICALLY_CORRECT_LIGHTS )
449: 		float distanceFalloff = 1.0 / max( pow( lightDistance, decayExponent ), 0.01 );
450: 		if ( cutoffDistance > 0.0 ) {
451: 			distanceFalloff *= pow2( saturate( 1.0 - pow4( lightDistance / cutoffDistance ) ) );
452: 		}
453: 		return distanceFalloff;
454: 	#else
455: 		if ( cutoffDistance > 0.0 && decayExponent > 0.0 ) {
456: 			return pow( saturate( - lightDistance / cutoffDistance + 1.0 ), decayExponent );
457: 		}
458: 		return 1.0;
459: 	#endif
460: }
