209: #ifdef ENVMAP_TYPE_CUBE_UV
210: 	#define cubeUV_maxMipLevel 8.0
211: 	#define cubeUV_minMipLevel 4.0
212: 	#define cubeUV_maxTileSize 256.0
213: 	#define cubeUV_minTileSize 16.0
214: 	float getFace( vec3 direction ) {
215: 		vec3 absDirection = abs( direction );
216: 		float face = - 1.0;
217: 		if ( absDirection.x > absDirection.z ) {
218: 			if ( absDirection.x > absDirection.y )
219: 				face = direction.x > 0.0 ? 0.0 : 3.0;
220: 			else
221: 				face = direction.y > 0.0 ? 1.0 : 4.0;
222: 		} else {
223: 			if ( absDirection.z > absDirection.y )
224: 				face = direction.z > 0.0 ? 2.0 : 5.0;
225: 			else
226: 				face = direction.y > 0.0 ? 1.0 : 4.0;
227: 		}
228: 		return face;
229: 	}
230: 	vec2 getUV( vec3 direction, float face ) {
231: 		vec2 uv;
232: 		if ( face == 0.0 ) {
233: 			uv = vec2( direction.z, direction.y ) / abs( direction.x );
234: 		} else if ( face == 1.0 ) {
235: 			uv = vec2( - direction.x, - direction.z ) / abs( direction.y );
236: 		} else if ( face == 2.0 ) {
237: 			uv = vec2( - direction.x, direction.y ) / abs( direction.z );
238: 		} else if ( face == 3.0 ) {
239: 			uv = vec2( - direction.z, direction.y ) / abs( direction.x );
240: 		} else if ( face == 4.0 ) {
241: 			uv = vec2( - direction.x, direction.z ) / abs( direction.y );
242: 		} else {
243: 			uv = vec2( direction.x, direction.y ) / abs( direction.z );
244: 		}
245: 		return 0.5 * ( uv + 1.0 );
246: 	}
247: 	vec3 bilinearCubeUV( sampler2D envMap, vec3 direction, float mipInt ) {
248: 		float face = getFace( direction );
249: 		float filterInt = max( cubeUV_minMipLevel - mipInt, 0.0 );
250: 		mipInt = max( mipInt, cubeUV_minMipLevel );
251: 		float faceSize = exp2( mipInt );
252: 		float texelSize = 1.0 / ( 3.0 * cubeUV_maxTileSize );
253: 		vec2 uv = getUV( direction, face ) * ( faceSize - 1.0 ) + 0.5;
254: 		if ( face > 2.0 ) {
255: 			uv.y += faceSize;
256: 			face -= 3.0;
257: 		}
258: 		uv.x += face * faceSize;
259: 		if ( mipInt < cubeUV_maxMipLevel ) {
260: 			uv.y += 2.0 * cubeUV_maxTileSize;
261: 		}
262: 		uv.y += filterInt * 2.0 * cubeUV_minTileSize;
263: 		uv.x += 3.0 * max( 0.0, cubeUV_maxTileSize - 2.0 * faceSize );
264: 		uv *= texelSize;
265: 		return texture2D( envMap, uv ).rgb;
266: 	}
267: 	#define r0 1.0
268: 	#define v0 0.339
269: 	#define m0 - 2.0
270: 	#define r1 0.8
271: 	#define v1 0.276
272: 	#define m1 - 1.0
273: 	#define r4 0.4
274: 	#define v4 0.046
275: 	#define m4 2.0
276: 	#define r5 0.305
277: 	#define v5 0.016
278: 	#define m5 3.0
279: 	#define r6 0.21
280: 	#define v6 0.0038
281: 	#define m6 4.0
282: 	float roughnessToMip( float roughness ) {
283: 		float mip = 0.0;
284: 		if ( roughness >= r1 ) {
285: 			mip = ( r0 - roughness ) * ( m1 - m0 ) / ( r0 - r1 ) + m0;
286: 		} else if ( roughness >= r4 ) {
287: 			mip = ( r1 - roughness ) * ( m4 - m1 ) / ( r1 - r4 ) + m1;
288: 		} else if ( roughness >= r5 ) {
289: 			mip = ( r4 - roughness ) * ( m5 - m4 ) / ( r4 - r5 ) + m4;
290: 		} else if ( roughness >= r6 ) {
291: 			mip = ( r5 - roughness ) * ( m6 - m5 ) / ( r5 - r6 ) + m5;
292: 		} else {
293: 			mip = - 2.0 * log2( 1.16 * roughness );		}
294: 		return mip;
295: 	}
296: 	vec4 textureCubeUV( sampler2D envMap, vec3 sampleDir, float roughness ) {
297: 		float mip = clamp( roughnessToMip( roughness ), m0, cubeUV_maxMipLevel );
298: 		float mipF = fract( mip );
299: 		float mipInt = floor( mip );
300: 		vec3 color0 = bilinearCubeUV( envMap, sampleDir, mipInt );
301: 		if ( mipF == 0.0 ) {
302: 			return vec4( color0, 1.0 );
303: 		} else {
304: 			vec3 color1 = bilinearCubeUV( envMap, sampleDir, mipInt + 1.0 );
305: 			return vec4( mix( color0, color1, mipF ), 1.0 );
306: 		}
307: 	}
308: #endif
309: vec3 BRDF_Lambert( const in vec3 diffuseColor ) {
310: 	return RECIPROCAL_PI * diffuseColor;
311: }
312: vec3 F_Schlick( const in vec3 f0, const in float f90, const in float dotVH ) {
313: 	float fresnel = exp2( ( - 5.55473 * dotVH - 6.98316 ) * dotVH );
314: 	return f0 * ( 1.0 - fresnel ) + ( f90 * fresnel );
315: }
316: float V_GGX_SmithCorrelated( const in float alpha, const in float dotNL, const in float dotNV ) {
317: 	float a2 = pow2( alpha );
318: 	float gv = dotNL * sqrt( a2 + ( 1.0 - a2 ) * pow2( dotNV ) );
319: 	float gl = dotNV * sqrt( a2 + ( 1.0 - a2 ) * pow2( dotNL ) );
320: 	return 0.5 / max( gv + gl, EPSILON );
321: }
322: float D_GGX( const in float alpha, const in float dotNH ) {
323: 	float a2 = pow2( alpha );
324: 	float denom = pow2( dotNH ) * ( a2 - 1.0 ) + 1.0;
325: 	return RECIPROCAL_PI * a2 / pow2( denom );
326: }
327: vec3 BRDF_GGX( const in vec3 lightDir, const in vec3 viewDir, const in vec3 normal, const in vec3 f0, const in float f90, const in float roughness ) {
328: 	float alpha = pow2( roughness );
329: 	vec3 halfDir = normalize( lightDir + viewDir );
330: 	float dotNL = saturate( dot( normal, lightDir ) );
331: 	float dotNV = saturate( dot( normal, viewDir ) );
332: 	float dotNH = saturate( dot( normal, halfDir ) );
333: 	float dotVH = saturate( dot( viewDir, halfDir ) );
334: 	vec3 F = F_Schlick( f0, f90, dotVH );
335: 	float V = V_GGX_SmithCorrelated( alpha, dotNL, dotNV );
336: 	float D = D_GGX( alpha, dotNH );
337: 	return F * ( V * D );
338: }
339: vec2 LTC_Uv( const in vec3 N, const in vec3 V, const in float roughness ) {
340: 	const float LUT_SIZE = 64.0;
341: 	const float LUT_SCALE = ( LUT_SIZE - 1.0 ) / LUT_SIZE;
342: 	const float LUT_BIAS = 0.5 / LUT_SIZE;
343: 	float dotNV = saturate( dot( N, V ) );
344: 	vec2 uv = vec2( roughness, sqrt( 1.0 - dotNV ) );
345: 	uv = uv * LUT_SCALE + LUT_BIAS;
346: 	return uv;
347: }
348: float LTC_ClippedSphereFormFactor( const in vec3 f ) {
349: 	float l = length( f );
350: 	return max( ( l * l + f.z ) / ( l + 1.0 ), 0.0 );
351: }
352: vec3 LTC_EdgeVectorFormFactor( const in vec3 v1, const in vec3 v2 ) {
353: 	float x = dot( v1, v2 );
354: 	float y = abs( x );
355: 	float a = 0.8543985 + ( 0.4965155 + 0.0145206 * y ) * y;
356: 	float b = 3.4175940 + ( 4.1616724 + y ) * y;
357: 	float v = a / b;
358: 	float theta_sintheta = ( x > 0.0 ) ? v : 0.5 * inversesqrt( max( 1.0 - x * x, 1e-7 ) ) - v;
359: 	return cross( v1, v2 ) * theta_sintheta;
360: }
361: vec3 LTC_Evaluate( const in vec3 N, const in vec3 V, const in vec3 P, const in mat3 mInv, const in vec3 rectCoords[ 4 ] ) {
362: 	vec3 v1 = rectCoords[ 1 ] - rectCoords[ 0 ];
363: 	vec3 v2 = rectCoords[ 3 ] - rectCoords[ 0 ];
364: 	vec3 lightNormal = cross( v1, v2 );
365: 	if( dot( lightNormal, P - rectCoords[ 0 ] ) < 0.0 ) return vec3( 0.0 );
366: 	vec3 T1, T2;
367: 	T1 = normalize( V - N * dot( V, N ) );
368: 	T2 = - cross( N, T1 );
369: 	mat3 mat = mInv * transposeMat3( mat3( T1, T2, N ) );
370: 	vec3 coords[ 4 ];
371: 	coords[ 0 ] = mat * ( rectCoords[ 0 ] - P );
372: 	coords[ 1 ] = mat * ( rectCoords[ 1 ] - P );
373: 	coords[ 2 ] = mat * ( rectCoords[ 2 ] - P );
374: 	coords[ 3 ] = mat * ( rectCoords[ 3 ] - P );
375: 	coords[ 0 ] = normalize( coords[ 0 ] );
376: 	coords[ 1 ] = normalize( coords[ 1 ] );
377: 	coords[ 2 ] = normalize( coords[ 2 ] );
378: 	coords[ 3 ] = normalize( coords[ 3 ] );
379: 	vec3 vectorFormFactor = vec3( 0.0 );
380: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 0 ], coords[ 1 ] );
381: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 1 ], coords[ 2 ] );
382: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 2 ], coords[ 3 ] );
383: 	vectorFormFactor += LTC_EdgeVectorFormFactor( coords[ 3 ], coords[ 0 ] );
384: 	float result = LTC_ClippedSphereFormFactor( vectorFormFactor );
385: 	return vec3( result );
386: }
387: float G_BlinnPhong_Implicit( ) {
388: 	return 0.25;
389: }
390: float D_BlinnPhong( const in float shininess, const in float dotNH ) {
391: 	return RECIPROCAL_PI * ( shininess * 0.5 + 1.0 ) * pow( dotNH, shininess );
392: }
393: vec3 BRDF_BlinnPhong( const in vec3 lightDir, const in vec3 viewDir, const in vec3 normal, const in vec3 specularColor, const in float shininess ) {
394: 	vec3 halfDir = normalize( lightDir + viewDir );
395: 	float dotNH = saturate( dot( normal, halfDir ) );
396: 	float dotVH = saturate( dot( viewDir, halfDir ) );
397: 	vec3 F = F_Schlick( specularColor, 1.0, dotVH );
398: 	float G = G_BlinnPhong_Implicit( );
399: 	float D = D_BlinnPhong( shininess, dotNH );
400: 	return F * ( G * D );
401: }
402: #if defined( USE_SHEEN )
403: float D_Charlie( float roughness, float dotNH ) {
404: 	float alpha = pow2( roughness );
405: 	float invAlpha = 1.0 / alpha;
406: 	float cos2h = dotNH * dotNH;
407: 	float sin2h = max( 1.0 - cos2h, 0.0078125 );
408: 	return ( 2.0 + invAlpha ) * pow( sin2h, invAlpha * 0.5 ) / ( 2.0 * PI );
409: }
410: float V_Neubelt( float dotNV, float dotNL ) {
411: 	return saturate( 1.0 / ( 4.0 * ( dotNL + dotNV - dotNL * dotNV ) ) );
412: }
413: vec3 BRDF_Sheen( const in vec3 lightDir, const in vec3 viewDir, const in vec3 normal, vec3 sheenColor, const in float sheenRoughness ) {
414: 	vec3 halfDir = normalize( lightDir + viewDir );
415: 	float dotNL = saturate( dot( normal, lightDir ) );
416: 	float dotNV = saturate( dot( normal, viewDir ) );
417: 	float dotNH = saturate( dot( normal, halfDir ) );
418: 	float D = D_Charlie( sheenRoughness, dotNH );
419: 	float V = V_Neubelt( dotNV, dotNL );
420: 	return sheenColor * ( D * V );
421: }
