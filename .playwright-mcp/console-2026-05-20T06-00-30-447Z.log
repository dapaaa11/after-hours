303: float getDistanceAttenuation( const in float lightDistance, const in float cutoffDistance, const in float decayExponent ) {
304: 	#if defined ( PHYSICALLY_CORRECT_LIGHTS )
305: 		float distanceFalloff = 1.0 / max( pow( lightDistance, decayExponent ), 0.01 );
306: 		if ( cutoffDistance > 0.0 ) {
307: 			distanceFalloff *= pow2( saturate( 1.0 - pow4( lightDistance / cutoffDistance ) ) );
308: 		}
309: 		return distanceFalloff;
310: 	#else
311: 		if ( cutoffDistance > 0.0 && decayExponent > 0.0 ) {
312: 			return pow( saturate( - lightDistance / cutoffDistance + 1.0 ), decayExponent );
313: 		}
314: 		return 1.0;
315: 	#endif
316: }
