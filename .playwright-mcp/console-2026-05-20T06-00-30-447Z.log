248: vec3 BRDF_BlinnPhong( const in vec3 lightDir, const in vec3 viewDir, const in vec3 normal, const in vec3 specularColor, const in float shininess ) {
249: 	vec3 halfDir = normalize( lightDir + viewDir );
250: 	float dotNH = saturate( dot( normal, halfDir ) );
251: 	float dotVH = saturate( dot( viewDir, halfDir ) );
252: 	vec3 F = F_Schlick( specularColor, 1.0, dotVH );
253: 	float G = G_BlinnPhong_Implicit( );
254: 	float D = D_BlinnPhong( shininess, dotNH );
255: 	return F * ( G * D );
256: }
