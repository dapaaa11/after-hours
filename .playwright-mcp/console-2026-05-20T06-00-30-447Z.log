171: float V_GGX_SmithCorrelated( const in float alpha, const in float dotNL, const in float dotNV ) {
172: 	float a2 = pow2( alpha );
173: 	float gv = dotNL * sqrt( a2 + ( 1.0 - a2 ) * pow2( dotNV ) );
174: 	float gl = dotNV * sqrt( a2 + ( 1.0 - a2 ) * pow2( dotNL ) );
175: 	return 0.5 / max( gv + gl, EPSILON );
176: }
177: float D_GGX( const in float alpha, const in float dotNH ) {
178: 	float a2 = pow2( alpha );
179: 	float denom = pow2( dotNH ) * ( a2 - 1.0 ) + 1.0;
180: 	return RECIPROCAL_PI * a2 / pow2( denom );
