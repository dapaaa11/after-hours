283: 	result += shCoefficients[ 1 ] * 2.0 * 0.511664 * y;
284: 	result += shCoefficients[ 2 ] * 2.0 * 0.511664 * z;
285: 	result += shCoefficients[ 3 ] * 2.0 * 0.511664 * x;
286: 	result += shCoefficients[ 4 ] * 2.0 * 0.429043 * x * y;
