425: vec3 shGetIrradianceAt( in vec3 normal, in vec3 shCoefficients[ 9 ] ) {
426: 	float x = normal.x, y = normal.y, z = normal.z;
427: 	vec3 result = shCoefficients[ 0 ] * 0.886227;
428: 	result += shCoefficients[ 1 ] * 2.0 * 0.511664 * y;
429: 	result += shCoefficients[ 2 ] * 2.0 * 0.511664 * z;
430: 	result += shCoefficients[ 3 ] * 2.0 * 0.511664 * x;
431: 	result += shCoefficients[ 4 ] * 2.0 * 0.429043 * x * y;
432: 	result += shCoefficients[ 5 ] * 2.0 * 0.429043 * y * z;
433: 	result += shCoefficients[ 6 ] * ( 0.743125 * z * z - 0.247708 );
434: 	result += shCoefficients[ 7 ] * 2.0 * 0.429043 * x * z;
435: 	result += shCoefficients[ 8 ] * 0.429043 * ( x * x - y * y );
436: 	return result;
437: }
