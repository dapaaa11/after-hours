288: 	result += shCoefficients[ 6 ] * ( 0.743125 * z * z - 0.247708 );
289: 	result += shCoefficients[ 7 ] * 2.0 * 0.429043 * x * z;
290: 	result += shCoefficients[ 8 ] * 0.429043 * ( x * x - y * y );
291: 	return result;
